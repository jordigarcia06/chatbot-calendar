    {
      "parameters": {
        "jsCode": "const raw = $('AI Agent').first().json.output;\n\nconst jsonMatch = raw.match(/\\{[\\s\\S]*\\}/);\nif (!jsonMatch) throw new Error('No se encontró JSON en el output');\n\nconst parsed = JSON.parse(jsonMatch[0]);\n\nconst dias = {\n  'lunes': 1, 'martes': 2, 'miércoles': 3, 'miercoles': 3,\n  'jueves': 4, 'viernes': 5, 'sábado': 6, 'sabado': 6, 'domingo': 0\n};\n\nconst hoy = new Date();\nconst diaObjetivo = dias[parsed.dia.toLowerCase()];\nconst diaHoy = hoy.getDay();\nlet diff = diaObjetivo - diaHoy;\nif (diff <= 0) diff += 7;\n\nconst fechaClase = new Date(hoy);\nfechaClase.setDate(hoy.getDate() + diff);\n\nconst [hora, minutos] = parsed.hora.split(':');\nfechaClase.setHours(parseInt(hora) - 2, parseInt(minutos), 0, 0);\n\nconst fechaFin = new Date(fechaClase);\nfechaFin.setHours(fechaFin.getHours() + 1);\n\nreturn [{\n  json: {\n    clase: parsed.clase,\n    dia: parsed.dia,\n    hora: parsed.hora,\n    nombre: parsed.nombre,\n    chat_id: $('Telegram Trigger').first().json.message.chat.id,\n    fecha_inicio: fechaClase.toISOString(),\n    fecha_fin: fechaFin.toISOString()\n  }\n}];"
      },
